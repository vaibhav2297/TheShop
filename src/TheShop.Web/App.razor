<Router AppAssembly="@typeof(App).Assembly" NotFoundPage="typeof(TheShop.Web.Pages.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(TheShop.Web.Components.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
</Router>
