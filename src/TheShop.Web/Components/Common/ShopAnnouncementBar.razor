@inherits MudBlazor.MudComponentBase

<MudPaper Class="@Classname"
          Style="@Style"
          Square
          Elevation="0">

    <MudStack AlignItems="AlignItems.Center"
              Justify="Justify.Center"
              Class="py-1 px-4">

        <MudText Typo="Typo.body2">@Message</MudText>

    </MudStack>

</MudPaper>
