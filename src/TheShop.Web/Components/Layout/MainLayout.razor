@inherits LayoutComponentBase

@using TheShop.Web.Components.Common
@using TheShop.Web.Components.Navigation
@using TheShop.Web.Theme

<MudThemeProvider Theme="@ShopTheme.BuildTheme()"
                  IsDarkMode="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<ShopLoadingOverlay />

<MudLayout Class="d-flex flex-column overflow-hidden">

    @if (Announcement.HasAnnouncement)
    {
        <ShopAnnouncementBar Message="@Announcement.Message" />
    }

    <ShopAppBar />

    @if (Breadcrumbs.HasTrail)
    {
        <ShopBreadcrumbs Items="@Breadcrumbs.Trail" />
    }

    <MudMainContent Class="flex-grow-1 overflow-y-auto overflow-x-hidden min-height-0 pt-0">

        <MudStack Spacing="0" AlignItems="AlignItems.Stretch" Class="min-height-full">

            @Body

            @if (Footer.Visible)
            {
                <ShopFooter Class="mt-auto" />
            }

        </MudStack> 
    </MudMainContent>

</MudLayout>
