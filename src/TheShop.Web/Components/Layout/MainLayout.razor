@inherits LayoutComponentBase
@using TheShop.Web.Theme

<MudThemeProvider Theme="@ShopTheme.BuildTheme()" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudText Typo="Typo.h6">@Strings.AppName</MudText>
        <MudSpacer />
        <MudIconButton Icon="@ShopIcons.Cart"
                       Color="Color.Inherit"
                       Href="/cart"
                       aria-label="@Strings.Nav_Cart" />
        <MudIconButton Icon="@ShopIcons.Account"
                       Color="Color.Inherit"
                       Href="/account"
                       aria-label="@Strings.Nav_Account" />
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
