@using TheShop.Web.Common
@using TheShop.Web.Resources
@using TheShop.Web.Theme
@using TheShop.Web.Components.Common

<MudAppBar Color="Color.Surface" Elevation="1">

    @* Logo *@
    <MudLink Href="@Routes.Home" Underline="Underline.None" Color="Color.Inherit">
        <MudImage Src="/images/logo/logo-header.svg"
                  Alt="@Strings.AppName"
                  Width="120"
                  Height="40"
                  ObjectFit="ObjectFit.Contain" />
    </MudLink>

    <MudSpacer />

    @* Primary navigation *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="@Routes.Home">@Strings.Nav_Home</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="@Routes.Products">@Strings.Nav_Products</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="@Routes.Categories">@Strings.Nav_Categories</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="@Routes.Brands">@Strings.Nav_Brands</MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="@Routes.Deals">@Strings.Nav_Deals</MudButton>
    </MudStack>

    <MudSpacer />

    @* Action icons *@
    <MudIconButton Icon="@ShopIcons.Interface.Search_Magnifying_Glass"
                   Color="Color.Primary"
                   aria-label="@Strings.Nav_Search" />

    <MudIconButton Icon="@ShopIcons.Interface.Shopping_Cart_01"
                   Color="Color.Primary"
                   Href="@Routes.Cart"
                   aria-label="@Strings.Nav_Cart" />

    <AuthorizeView>
        <Authorized>
            <MudMenu Icon="@ShopIcons.User.User_Circle"
                     Color="Color.Primary"
                     AnchorOrigin="Origin.BottomRight"
                     TransformOrigin="Origin.TopRight"
                     aria-label="@Strings.Nav_Account">
                <MudMenuItem OnClick="OnSignOutAsync">@Strings.Logout</MudMenuItem>
            </MudMenu>
        </Authorized>
        <NotAuthorized>
            <MudIconButton Icon="@ShopIcons.User.User_Circle"
                           Color="Color.Primary"
                           Href="@Routes.Auth.SignIn"
                           aria-label="@Strings.Nav_Account" />
        </NotAuthorized>
    </AuthorizeView>

</MudAppBar>
