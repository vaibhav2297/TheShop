@layout TheShop.Web.Components.Layout.AuthLayout
@attribute [AllowAnonymous]
@using TheShop.Web.Common
@using TheShop.Web.Components.Common

<PageTitle>@Strings.SignUp_PageTitle</PageTitle>

<MudGrid Spacing="0" Class="mud-height-full">

    @* Left panel: sign-up form — space-between aligns heading at top, form at bottom *@
    <MudItem xs="12" md="6">
        <MudStack Class="mud-height-full pa-16"
                  Justify="Justify.SpaceBetween">

            @* Top bar: cross-navigation link only *@
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd">
                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           Href="@Routes.Auth.SignIn">@Strings.Login</MudButton>
            </MudStack>

            @* Hero heading block *@
            <MudStack Spacing="2">
                <MudText Typo="Typo.h2" Color="Color.Primary">@Strings.SignUp_Heading</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">@Strings.SignUp_Instruction</MudText>
            </MudStack>

            @* Form block *@
            <MudStack Spacing="4">
                <MudForm @ref="_form"
                         @bind-IsValid="_isFormValid"
                         SuppressImplicitSubmission="true">
                    <MudStack Spacing="3">

                        @* Name row: first + last side-by-side *@
                        <MudGrid Spacing="3">
                            <MudItem xs="12" sm="6">
                                <MudTextField T="string"
                                              @bind-Value="_firstName"
                                              Placeholder="@Strings.FirstName_Label"
                                              Variant="Variant.Filled"
                                              FullWidth="true"
                                              Required="true"
                                              RequiredError="@Strings.Auth_FirstName_Required"
                                              Immediate="true"
                                              autocomplete="given-name" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField T="string"
                                              @bind-Value="_lastName"
                                              Placeholder="@Strings.LastName_Label"
                                              Variant="Variant.Filled"
                                              FullWidth="true"
                                              Required="true"
                                              RequiredError="@Strings.Auth_LastName_Required"
                                              Immediate="true"
                                              autocomplete="family-name" />
                            </MudItem>
                        </MudGrid>

                        <MudTextField T="string"
                                      @bind-Value="_email"
                                      Placeholder="@Strings.Email_Label"
                                      InputType="InputType.Email"
                                      Variant="Variant.Filled"
                                      FullWidth="true"
                                      Required="true"
                                      RequiredError="@Strings.Email_Required"
                                      Validation="@_emailValidation"
                                      Immediate="true"
                                      autocomplete="email" />

                        <MudDatePicker Label="@Strings.DateOfBirth_Label"
                                       HelperText="@Strings.DateOfBirth_Hint"
                                       Variant="Variant.Filled"
                                       @bind-Date="_dateOfBirth"
                                       MaxDate="@_maxDate"
                                       Required="true"
                                       RequiredError="@Strings.Auth_Dob_InPast"
                                       Validation="@_dobValidation"
                                       Editable="true"
                                       DateFormat="yyyy-MM-dd" />

                        <MudCheckBox T="bool"
                                     @bind-Value="_ageConfirmed"
                                     Color="Color.Primary"
                                     Required="true"
                                     RequiredError="@Strings.Auth_Underage">
                            <MudText Typo="Typo.body2">@Strings.SignUp_AgeConfirm</MudText>
                        </MudCheckBox>

                        <BusyFor Key="@BusyKeys.Auth.SignUp" Context="busy">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Large"
                                       Disabled="@(!_isFormValid || busy)"
                                       OnClick="OnSendCodeAsync">
                                @if (busy)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                }
                                @Strings.Auth_SendCode
                            </MudButton>
                        </BusyFor>

                    </MudStack>
                </MudForm>
            </MudStack>

        </MudStack>
    </MudItem>

    @* Right panel: brand splash — hidden on small screens *@
    <MudItem xs="12" md="6" Class="d-none d-md-flex mud-theme-surface">
        <MudStack AlignItems="AlignItems.Center"
                  Justify="Justify.Center"
                  Class="mud-height-full pa-4"
                  Spacing="4">
            <MudImage Src="/images/logo/logo.svg"
                      Alt="@Strings.AppName"
                      Width="320"
                      Height="320"
                      ObjectFit="ObjectFit.Contain" />
            <MudText Typo="Typo.h6" Color="Color.Secondary">@Strings.App_Tagline</MudText>
        </MudStack>
    </MudItem>

</MudGrid>
