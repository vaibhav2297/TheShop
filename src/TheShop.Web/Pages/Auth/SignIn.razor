@attribute [AllowAnonymous]
@using TheShop.Web.Common
@using TheShop.Web.Components.Common

<PageTitle>@Strings.SignIn_PageTitle</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="py-8">
    <MudPaper Class="pa-8" Elevation="2">
        <MudText Typo="Typo.h4" Class="mb-6">@Strings.SignIn_Heading</MudText>

        <MudForm @ref="_form" @bind-IsValid="_isFormValid">
            <MudTextField T="string"
                          @bind-Value="_email"
                          Label="@Strings.Email_Label"
                          Placeholder="@Strings.Email_Placeholder"
                          InputType="InputType.Email"
                          Required="true"
                          RequiredError="@Localizer[nameof(Strings.Email_Required)]"
                          Validation="@(new Func<string, string?>(ValidateEmail))"
                          Class="mb-3" />

            <BusyFor Key="@BusyKeys.Auth.SignIn" Context="busy">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Disabled="@(!_isFormValid || busy)"
                           OnClick="OnSubmitAsync"
                           Class="mt-4">
                    @if (busy)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    @Strings.Auth_SendCode
                </MudButton>
            </BusyFor>
        </MudForm>

        <MudText Typo="Typo.body2" Class="mt-6 text-center">
            @Strings.SignIn_NoAccount
            <MudLink Href="@Routes.Auth.SignUp">@Strings.SignUp</MudLink>
        </MudText>
    </MudPaper>
</MudContainer>
