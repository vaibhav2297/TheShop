@layout TheShop.Web.Components.Layout.AuthLayout
@attribute [AllowAnonymous]
@using TheShop.Web.Common
@using TheShop.Web.Components.Common

<PageTitle>@Strings.Verify_PageTitle</PageTitle>

<MudGrid Spacing="0" Class="mud-height-full">

    @* Left panel: OTP entry — space-between aligns heading at top, form at bottom *@
    <MudItem xs="12" md="6">
        <MudStack Class="mud-height-full pa-16"
                  Justify="Justify.SpaceBetween">

            @* Top bar: cross-navigation link only *@
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd">
                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           Href="@Routes.Auth.SignUp">@Strings.SignUp</MudButton>
            </MudStack>

            @* Hero heading block *@
            <MudStack Spacing="2">
                <MudText Typo="Typo.h2" Color="Color.Primary">@Strings.Verify_Heading</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    @string.Format(Strings.Verify_Subheading, _email)
                </MudText>
            </MudStack>

            @* Form block *@
            <MudStack Spacing="4">
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    @Strings.Verify_CodeLabel
                </MudText>

                <MudForm @ref="_form"
                         @bind-IsValid="_isFormValid"
                         SuppressImplicitSubmission="true">
                    <MudStack Spacing="3">

                        @* Six individual digit boxes *@
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            @for (var i = 0; i < 6; i++)
                            {
                                var idx = i;
                                <MudTextField T="string"
                                              id="@($"otp-{idx}")"
                                              Value="@_digits[idx]"
                                              ValueChanged="@((v) => OnDigitChanged(idx, v))"
                                              Variant="Variant.Filled"
                                              Typo="Typo.body2"
                                              InputType="InputType.Number"
                                              MaxLength="1"
                                              Style="width:56px;text-align:center;"
                                              autocomplete="one-time-code"
                                              Class="otp-digit-field" />
                            }
                        </MudStack>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Strings.Verify_CodeHint</MudText>

                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <BusyFor Key="@BusyKeys.Auth.SignInVerify" Context="busy">
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Large"
                                           Disabled="@(!_isCodeComplete || busy)"
                                           OnClick="OnVerifyAsync">
                                    @if (busy)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    }
                                    @Strings.Verify_Submit
                                </MudButton>
                            </BusyFor>

                            <BusyFor Key="@BusyKeys.Auth.ResendOtp" Context="resending">
                                <MudButton Variant="Variant.Text"
                                           Color="Color.Primary"
                                           EndIcon="@ShopIcons.Arrow.Arrow_Right_MD"
                                           Disabled="@(_resendCooldown > 0 || resending)"
                                           OnClick="OnResendAsync">
                                    @if (_resendCooldown > 0)
                                    {
                                        @string.Format(Strings.Verify_ResendIn, _resendCooldown)
                                    }
                                    else
                                    {
                                        @Strings.Verify_Resend
                                    }
                                </MudButton>
                            </BusyFor>
                        </MudStack>

                    </MudStack>
                </MudForm>
            </MudStack>

        </MudStack>
    </MudItem>

    @* Right panel: brand splash — hidden on small screens *@
    <MudItem xs="12" md="6" Class="d-none d-md-flex mud-theme-surface">
        <MudStack AlignItems="AlignItems.Center"
                  Justify="Justify.Center"
                  Class="flex-1 ma-4 mud-surface"
                  Spacing="4">
            <MudImage Src="/images/logo/logo.svg"
                      Alt="@Strings.AppName"
                      Width="320"
                      Height="320"
                      ObjectFit="ObjectFit.Contain" />
            <MudText Typo="Typo.h6" Color="Color.Secondary">@Strings.App_Tagline</MudText>
        </MudStack>
    </MudItem>

</MudGrid>
