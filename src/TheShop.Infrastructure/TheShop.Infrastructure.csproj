         GHSA-59j7-ghrg-fj52 affects < 7.1.2; pinning to 8.* resolves it. -->
    <PackageReference Include="System.IdentityModel.Tokens.Jwt" Version="8.*" />
    <PackageReference Include="Microsoft.IdentityModel.JsonWebTokens" Version="8.*" />
  </ItemGroup>

</Project>
